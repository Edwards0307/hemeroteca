# EditorConfig: https://editorconfig.org
root = true

# ─── Todos los archivos ───────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ─── JavaScript, TypeScript, JSON, CSS ───────────
[*.{js,ts,tsx,jsx,json,css,scss}]
indent_style = space
indent_size = 2

# ─── C# ──────────────────────────────────────────
[*.cs]
indent_style = space
indent_size = 4

# ─── XML (archivos .csproj, .sln) ────────────────
[*.{csproj,sln,xml}]
indent_style = space
indent_size = 2

# ─── Markdown ────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
